{rank=same; "1a";"2a";"3a";"4a";}
{rank=same; "1b";"2b";"3b";"4b";}
{rank=same; "1c";"2c";"3c";"4c";}

  "Conclusions" [URL="#Conclusions"; label="Conclusions";fontname="Helvetica";];
